# ─────────────────────────────────────────────────────────────
# Variables d'environnement — Le Relais Web (Next.js)
# Copier en .env.local pour le dev. En prod : les définir dans Vercel
# (Project Settings → Environment Variables). NE JAMAIS commiter de vraie valeur.
# ─────────────────────────────────────────────────────────────

# Base de données MySQL (Hostinger, Remote MySQL activé)
# Format : mysql://USER:MOTDEPASSE@HOTE:3306/NOM_BASE
DATABASE_URL=mysql://user:motdepasse@srvXXXX.hstgr.io:3306/nom_base

# Secret de signature des sessions (JWT). Générer une valeur aléatoire longue :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=remplacer_par_une_valeur_aleatoire_longue

# Stripe — clés depuis dashboard.stripe.com
# Dev/test : sk_test_... ; Prod : sk_live_... (UNIQUEMENT dans Vercel, jamais ici)
STRIPE_SECRET_KEY=
# Secret de signature du webhook (whsec_...) créé dans Stripe → Webhooks
STRIPE_WEBHOOK_SECRET=

# URL absolue de l'app (redirections Stripe + liens des emails)
# Dev : http://localhost:3001  ·  Prod : https://www.lerelaisweb.com
APP_URL=http://localhost:3001

# Email transactionnel (SMTP Hostinger : bienvenue, reset mot de passe, devis)
# Compte : noreply@lerelaisweb.com — hôte/port depuis hPanel > Emails > Configuration.
# Laisser vide = emails désactivés proprement (le site marche, juste pas d'envoi).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@lerelaisweb.com
SMTP_PASS=
SMTP_FROM=Le Relais Web <noreply@lerelaisweb.com>
